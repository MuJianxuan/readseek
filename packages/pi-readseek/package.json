{
  "name": "pi-readseek",
  "version": "0.8.2",
  "description": "Pi extension for readseek-backed hash-anchored read/edit/grep, structural code maps, structural search, and file exploration",
  "type": "module",
  "exports": {
    ".": "./dist/index.ts"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "hashline",
    "code-map",
    "structural-search"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarkkojs/readseek.git"
  },
  "author": "Maxwell Newman",
  "license": "Apache-2.0",
  "pi": {
    "extensions": [
      "./dist/index.ts"
    ]
  },
  "files": [
    "dist/",
    "prompts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun build index.ts --outfile dist/index.ts --target=node --packages=external",
    "prepack": "npm run build",
    "test": "npm run build && node scripts/vitest-run.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@jarkkojs/readseek": "^0.8.2",
    "diff": "^8.0.3",
    "xxhash-wasm": "^1.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.79.6",
    "@earendil-works/pi-tui": "^0.78.0",
    "@sinclair/typebox": "^0.34.48",
    "@types/node": "^25.5.0",
    "jiti": "^2.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "directories": {
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/jarkkojs/readseek/issues"
  },
  "homepage": "https://github.com/jarkkojs/readseek/tree/main/packages/pi-readseek#readme"
}
